#!/usr/bin/env bash
# git-mess — version arbitrary files in a hidden object store, no repo required.
#
# Histories live as refs under refs/mess/ in a bare store. Deleting a
# history deletes one ref; no branch anywhere is rewritten.
set -euo pipefail

# Store resolution: $GIT_MESS_STORE, else the nearest .git-mess.git walking
# up from the current directory, else the global ~/.git-mess.git.
resolve_store() {
    if [ -n "${GIT_MESS_STORE:-}" ]; then echo "$GIT_MESS_STORE"; return; fi
    local d="$PWD"
    while [ "$d" != "/" ]; do
        if [ -d "$d/.git-mess.git" ]; then echo "$d/.git-mess.git"; return; fi
        d=$(dirname "$d")
    done
    echo "$HOME/.git-mess.git"
}
STORE=$(resolve_store)

# Paths are recorded relative to the store's root (the directory holding
# .git-mess.git), which makes a local mess relocatable and clonable. The
# global store roots at / and records absolute paths.
set_root() {
    if [ "$STORE" = "$HOME/.git-mess.git" ]; then ROOT=""; return; fi
    local parent; parent=$(dirname "$STORE")
    if [ -d "$parent" ]; then ROOT=$(cd "$parent" && pwd); else ROOT="$parent"; fi
}
set_root

g() { git --git-dir "$STORE" "$@"; }

usage() {
    cat <<'EOF'
usage: git mess <command> [args]

  init [<dir>]                                    create a local store in <dir> (default .)
  store                                           print which store is in use
  clone <url> [<dir>]                             copy a remote mess and materialize its files
  snapshot <file>... [-n <name>] [-m <msg>] [-f]  record a new version (-f: allow a file
                                                  already tracked by another history)
  snapshot --all [-m <msg>]                       re-snapshot every changed history
  diff [--disk]                                   diff every history (no name = whole mess)
  list                                            list all histories
  status [<name>...]                              disk vs last snapshot (all if no name)
  untracked [<dir>]                               files no history tracks (default: store
                                                  root, or cwd for the global store)
  log <name>                                      show a history's versions
  show <name> [<rev>] [<path>]                    print file content at a version
  diff <name> [<rev1> [<rev2>]] [--disk]          diff versions (default: last change);
                                                  --disk: a version (default tip) vs disk
  restore <name>|--all [<rev>]                    write files back to their paths
  move <old-name> <new-name>                      rename a history; if its file is still
                                                  on disk, move the file too
  delete <name> [--prune]                         drop a history (--prune: gc now)

<name> defaults to the file's path (relative to the store root for local
stores). <rev> is any revision expression, e.g. a short SHA from `log`.
EOF
    exit 1
}

ensure_store() {
    [ -d "$STORE" ] || git init -q --bare "$STORE"
}

sanitize() {
    printf '%s' "$1" | tr ' ~^:?*[\\' '--------'
}

# Absolute path -> path as recorded in trees (root-relative when possible).
tree_path() {
    local abs="$1"
    if [ -n "$ROOT" ]; then
        case "$abs" in "$ROOT"/*) printf '%s\n' "${abs#"$ROOT"/}"; return ;; esac
    fi
    printf '%s\n' "${abs#/}"
}

# Tree path -> filesystem path.
disk_path() {
    if [ -n "$ROOT" ]; then printf '%s\n' "$ROOT/$1"; else printf '%s\n' "/$1"; fi
}

# Build a throwaway tree from the current disk contents of <rev>'s files.
# Missing files are omitted (they show as deletions when diffed).
disk_tree() {
    local rev="$1" path dest blob mode dtdir
    dtdir=$(mktemp -d)
    export GIT_INDEX_FILE="$dtdir/index"
    g ls-tree -r --name-only "$rev" | while IFS= read -r path; do
        dest=$(disk_path "$path")
        [ -f "$dest" ] || continue
        blob=$(g hash-object -w "$dest")
        mode=100644; [ -x "$dest" ] && mode=100755
        g update-index --add --cacheinfo "$mode,$blob,$path"
    done
    g write-tree
    unset GIT_INDEX_FILE
    rm -rf "$dtdir"
}

# Map a name/path to its ref. Args that exist as files use their canonical
# path; ref-hostile characters are replaced with '-'.
name_to_ref() {
    local name="$1"
    if [ -e "$name" ]; then
        local abs; abs=$(cd "$(dirname "$name")" && pwd)/$(basename "$name")
        name=$(tree_path "$abs")
    else
        name="${name#/}"
    fi
    name=$(sanitize "$name")
    local ref="refs/mess/$name"
    git check-ref-format "$ref" || { echo "git-mess: invalid history name: $name" >&2; exit 1; }
    echo "$ref"
}

resolve_ref() {
    local ref; ref=$(name_to_ref "$1")
    g rev-parse -q --verify "$ref" >/dev/null || { echo "git-mess: no history: $1" >&2; exit 1; }
    echo "$ref"
}

cmd_init() {
    local dir="${1:-.}"
    [ -d "$dir" ] || { echo "git-mess: no such directory: $dir" >&2; exit 1; }
    dir=$(cd "$dir" && pwd)
    if [ -d "$dir/.git-mess.git" ]; then
        echo "git-mess: store already exists: $dir/.git-mess.git" >&2; exit 1
    fi
    if git -C "$dir" rev-parse --git-dir >/dev/null 2>&1; then
        echo "warning: $dir is inside a regular git repository" >&2
        echo "         the two coexist, but consider adding .git-mess.git/ to .gitignore" >&2
        echo "         and avoid snapshotting files that repo already tracks" >&2
    fi
    git init -q --bare "$dir/.git-mess.git"
    echo "created local store: $dir/.git-mess.git"
    echo "(used automatically by git mess anywhere under $dir)"
}

snapshot_all() {
    local msg="$1" ref name tip tree empty
    empty=$(g hash-object -t tree /dev/null)
    g for-each-ref --format='%(refname)' 'refs/mess/' | while IFS= read -r ref; do
        name=${ref#refs/mess/}
        tip=$(g rev-parse "$ref")
        tree=$(disk_tree "$ref")
        if [ "$tree" = "$(g rev-parse "$ref^{tree}")" ]; then
            echo "$name  (clean)"
        elif [ "$tree" = "$empty" ]; then
            echo "$name  (all files missing — skipped; use 'git mess delete' if intended)"
        else
            local commit
            commit=$(g commit-tree "$tree" -m "${msg:-snapshot: $name}" -p "$tip")
            g update-ref "$ref" "$commit"
            echo "$name -> $(g rev-parse --short "$commit")"
        fi
    done
}

cmd_snapshot() {
    local name="" msg="" force=0 all=0 files=()
    while [ $# -gt 0 ]; do
        case "$1" in
            -n) name="$2"; shift 2 ;;
            -m) msg="$2"; shift 2 ;;
            -f) force=1; shift ;;
            --all) all=1; shift ;;
            *)  files+=("$1"); shift ;;
        esac
    done
    if [ "$all" -eq 1 ]; then
        ensure_store
        snapshot_all "$msg"
        return 0
    fi
    [ -n "${files[*]:-}" ] || usage
    if [ -z "$name" ]; then
        [ ${#files[@]} -eq 1 ] || { echo "git-mess: multi-file snapshots need -n <name>" >&2; exit 1; }
        name="${files[0]}"
    fi
    ensure_store
    local ref; ref=$(name_to_ref "$name")

    tmpdir=$(mktemp -d)
    trap 'rm -rf "${tmpdir:-}"' EXIT
    export GIT_INDEX_FILE="$tmpdir/index"

    local f abs tp blob mode other
    for f in "${files[@]}"; do
        [ -f "$f" ] || { echo "git-mess: not a file: $f" >&2; exit 1; }
        abs=$(cd "$(dirname "$f")" && pwd)/$(basename "$f")
        tp=$(tree_path "$abs")
        if [ "$force" -eq 0 ]; then
            other=$(g for-each-ref --format='%(refname:lstrip=2)' 'refs/mess/' | while IFS= read -r o; do
                [ "refs/mess/$o" = "$ref" ] && continue
                if g ls-tree -r --name-only "refs/mess/$o" | grep -qxF "$tp"; then
                    echo "$o"; break
                fi
            done)
            if [ -n "$other" ]; then
                echo "git-mess: $f is already tracked by mess '$other'; add -f to force double tracking in this mess" >&2
                exit 1
            fi
        fi
        blob=$(g hash-object -w "$abs")
        mode=100644; [ -x "$abs" ] && mode=100755
        g update-index --add --cacheinfo "$mode,$blob,$tp"
    done
    local tree; tree=$(g write-tree)
    unset GIT_INDEX_FILE

    local parent_args=() parent
    if parent=$(g rev-parse -q --verify "$ref"); then
        if [ "$(g rev-parse "$parent^{tree}")" = "$tree" ]; then
            echo "git-mess: no changes since last snapshot of $name"
            return 0
        fi
        parent_args=(-p "$parent")
    fi
    [ -n "$msg" ] || msg="snapshot: $name"
    local commit; commit=$(g commit-tree "$tree" -m "$msg" ${parent_args[@]+"${parent_args[@]}"})
    g update-ref "$ref" "$commit"
    echo "$name -> $(g rev-parse --short "$commit")"
}

cmd_list() {
    ensure_store
    g for-each-ref 'refs/mess/' \
        --format='%(refname:lstrip=2)  [%(objectname:short)]  %(creatordate:relative)'
}

cmd_log() {
    local ref; ref=$(resolve_ref "$1")
    g log --format='%h  %ad  %an  %s' --date=format:'%Y-%m-%d %H:%M:%S' "$ref"
}

cmd_status() {
    ensure_store
    local refs=() n ref name changes dest
    if [ $# -gt 0 ]; then
        for n in "$@"; do refs+=("$(resolve_ref "$n")"); done
    else
        while IFS= read -r ref; do refs+=("$ref"); done \
            < <(g for-each-ref --format='%(refname)' 'refs/mess/')
    fi
    [ -n "${refs[*]:-}" ] || { echo "git-mess: no histories"; return 0; }
    for ref in ${refs[@]+"${refs[@]}"}; do
        name=${ref#refs/mess/}
        changes=$(g ls-tree -r "$ref" | while read -r _ _ blob path; do
            dest=$(disk_path "$path")
            if [ ! -f "$dest" ]; then
                echo "  missing   $dest"
            elif [ "$(g hash-object "$dest")" != "$blob" ]; then
                echo "  modified  $dest"
            fi
        done)
        if [ -n "$changes" ]; then
            printf '%s\n%s\n' "$name" "$changes"
        else
            echo "$name  (clean)"
        fi
    done
}

cmd_untracked() {
    ensure_store
    local dir="${1:-}"
    if [ -z "$dir" ]; then
        if [ -n "$ROOT" ]; then dir="$ROOT"; else dir="$PWD"; fi
    fi
    [ -d "$dir" ] || { echo "git-mess: no such directory: $dir" >&2; exit 1; }
    dir=$(cd "$dir" && pwd)
    local prefix r tracked_tmp
    if [ -n "$ROOT" ]; then prefix="$ROOT/"; else prefix="/"; fi
    tracked_tmp=$(mktemp)
    g for-each-ref --format='%(refname)' 'refs/mess/' | while IFS= read -r r; do
        g ls-tree -r --name-only "$r"
    done | sort -u > "$tracked_tmp"
    # skip .git dirs and any subtree owned by another mess; the set-difference
    # runs as ONE awk pass (hash lookup per file), not a grep per file
    find "$dir" -mindepth 1 -type d \
            \( -name .git -o -name .git-mess.git -o -exec test -d '{}/.git-mess.git' \; \) -prune \
            -o -type f -print \
        | awk -v p="$prefix" -v tf="$tracked_tmp" '
            BEGIN { while ((getline line < tf) > 0) tracked[line] = 1 }
            {
                tp = $0
                if (index(tp, p) == 1) tp = substr(tp, length(p) + 1)
                else sub(/^\//, "", tp)
                if (!(tp in tracked)) print
            }'
    rm -f "$tracked_tmp"
}

cmd_show() {
    local ref; ref=$(resolve_ref "$1")
    local rev="${2:-}" path="${3:-}"
    # `show <name> <path>` — if the 2nd arg isn't a revision, treat it as the path
    if [ -n "$rev" ] && [ -z "$path" ] && ! g rev-parse -q --verify "$rev^{commit}" >/dev/null; then
        path="$rev"; rev=""
    fi
    [ -n "$rev" ] || rev="$ref"
    local names; names=$(g ls-tree -r --name-only "$rev")
    if [ -z "$path" ]; then
        [ "$(printf '%s\n' "$names" | grep -c .)" -eq 1 ] || {
            echo "git-mess: multi-file history, pass a path:" >&2
            printf '%s\n' "$names" >&2; exit 1; }
        path="$names"
    elif ! printf '%s\n' "$names" | grep -qxF "$path"; then
        # partial path: unique suffix/substring match wins
        local m; m=$(printf '%s\n' "$names" | grep -F "$path" || true)
        if [ "$(printf '%s\n' "$m" | grep -c .)" -eq 1 ]; then
            path="$m"
        else
            echo "git-mess: no unique match for '$path' in $1:" >&2
            printf '%s\n' "$names" >&2; exit 1
        fi
    fi
    g show "$rev:$path"
}

cmd_diff() {
    local disk=0 args=() a
    for a in "$@"; do
        case "$a" in --disk|-d) disk=1 ;; *) args+=("$a") ;; esac
    done
    if [ -z "${args[*]:-}" ]; then
        # no name: diff the whole mess, one section per changed history
        ensure_store
        local wref wname wfrom out
        g for-each-ref --format='%(refname)' 'refs/mess/' | while IFS= read -r wref; do
            wname=${wref#refs/mess/}
            if [ "$disk" -eq 1 ]; then
                out=$(g diff -M "$wref" "$(disk_tree "$wref")")
            else
                wfrom=$(g rev-parse -q --verify "$wref~1" 2>/dev/null) \
                    || wfrom=$(g hash-object -t tree /dev/null)
                out=$(g diff -M "$wfrom" "$wref")
            fi
            if [ -n "$out" ]; then printf '=== %s ===\n%s\n' "$wname" "$out"; fi
        done
        return 0
    fi
    local ref; ref=$(resolve_ref "${args[0]}")
    if [ "$disk" -eq 1 ]; then
        # a version (default tip) vs. what's on disk right now
        local rev="${args[1]:-$ref}"
        g diff -M "$rev" "$(disk_tree "$rev")"
        return 0
    fi
    local from="${args[1]:-}"
    if [ -z "$from" ]; then
        # first version has no parent: diff against the empty tree
        from=$(g rev-parse -q --verify "$ref~1" 2>/dev/null) \
            || from=$(g hash-object -t tree /dev/null)
    fi
    g diff -M "$from" "${args[2]:-$ref}"
}

restore_ref() {
    local ref="$1" rev="$2" dest
    g ls-tree -r "$rev" | while read -r mode _ blob path; do
        dest=$(disk_path "$path")
        mkdir -p "$(dirname "$dest")"
        g cat-file blob "$blob" > "$dest"
        [ "$mode" = 100755 ] && chmod +x "$dest"
        echo "restored $dest @ $(g rev-parse --short "$rev")"
    done
}

cmd_restore() {
    if [ "${1:-}" = "--all" ]; then
        local r
        g for-each-ref --format='%(refname)' 'refs/mess/' | while IFS= read -r r; do
            restore_ref "$r" "$r"
        done
        return 0
    fi
    local ref; ref=$(resolve_ref "$1")
    restore_ref "$ref" "${2:-$ref}"
}

cmd_move() {
    local old_ref; old_ref=$(resolve_ref "$1")
    local new="$2" did_mv=0 src=""
    # For a path-named single-file history whose file is still on disk,
    # move the actual file too (unless the destination already exists).
    local paths n
    paths=$(g ls-tree -r --name-only "$old_ref")
    n=$(printf '%s\n' "$paths" | grep -c .)
    if [ "$n" -eq 1 ]; then
        src=$(disk_path "${old_ref#refs/mess/}")
        if [ -f "$src" ] && [ ! -e "$new" ]; then
            mkdir -p "$(dirname "$new")"
            mv "$src" "$new"
            did_mv=1
        fi
    fi
    local new_ref; new_ref=$(name_to_ref "$new")
    if [ "$new_ref" = "$old_ref" ] || g rev-parse -q --verify "$new_ref" >/dev/null; then
        [ "$did_mv" -eq 1 ] && mv "$new" "$src"
        if [ "$new_ref" = "$old_ref" ]; then
            echo "git-mess: same history name" >&2
        else
            echo "git-mess: history already exists: $2" >&2
        fi
        exit 1
    fi
    g update-ref "$new_ref" "$(g rev-parse "$old_ref")"
    g update-ref -d "$old_ref"
    [ "$did_mv" -eq 1 ] && echo "moved file: $src -> $new"
    echo "moved: ${old_ref#refs/mess/} -> ${new_ref#refs/mess/}"
    if [ "$did_mv" -eq 1 ]; then
        # record a version under the new path so the history matches the disk
        local abs tp blob mode tree commit
        abs=$(cd "$(dirname "$new")" && pwd)/$(basename "$new")
        tp=$(tree_path "$abs")
        blob=$(g rev-parse "$new_ref:$paths")
        mode=100644; [ -x "$abs" ] && mode=100755
        tmpdir=$(mktemp -d)
        trap 'rm -rf "${tmpdir:-}"' EXIT
        export GIT_INDEX_FILE="$tmpdir/index"
        g update-index --add --cacheinfo "$mode,$blob,$tp"
        tree=$(g write-tree)
        unset GIT_INDEX_FILE
        commit=$(g commit-tree "$tree" \
            -m "move: ${old_ref#refs/mess/} -> ${new_ref#refs/mess/}" \
            -p "$(g rev-parse "$new_ref")")
        g update-ref "$new_ref" "$commit"
    fi
}

cmd_delete() {
    local prune=0 name=""
    for a in "$@"; do
        case "$a" in --prune) prune=1 ;; *) name="$a" ;; esac
    done
    local ref; ref=$(resolve_ref "$name")
    g update-ref -d "$ref"
    echo "deleted history: $name"
    if [ "$prune" -eq 1 ]; then
        g reflog expire --expire=now --all
        g gc -q --prune=now
        echo "pruned unreachable objects from $STORE"
    else
        echo "(objects remain until 'git mess delete --prune' or gc)"
    fi
}

cmd_clone() {
    local url="$1" dir="${2:-}"
    if [ -z "$dir" ]; then
        dir=$(basename "$url"); dir=${dir%.git}
        [ -n "$dir" ] || dir=mess
    fi
    [ ! -e "$dir" ] || { echo "git-mess: destination exists: $dir" >&2; exit 1; }
    mkdir -p "$dir"
    git init -q --bare "$dir/.git-mess.git"
    git --git-dir "$dir/.git-mess.git" fetch -q "$url" 'refs/mess/*:refs/mess/*'
    # re-root onto the clone and materialize every history at its tip
    STORE=$(cd "$dir" && pwd)/.git-mess.git
    ROOT=$(cd "$dir" && pwd)
    local r count=0
    while IFS= read -r r; do
        restore_ref "$r" "$r"
        count=$((count + 1))
    done < <(g for-each-ref --format='%(refname)' 'refs/mess/')
    echo "cloned $count histories into $dir"
}

cmd="${1:-}"; shift || true
case "$cmd" in
    init)     cmd_init "${1:-}" ;;
    store)    echo "$STORE" ;;
    clone)    cmd_clone "${1:?usage: git mess clone <url> [<dir>]}" "${2:-}" ;;
    snapshot) cmd_snapshot "$@" ;;
    list)     cmd_list ;;
    status)   cmd_status "$@" ;;
    untracked) cmd_untracked "${1:-}" ;;
    log)      cmd_log "${1:?usage: git mess log <name>}" ;;
    show)     cmd_show "${1:?usage: git mess show <name> [rev] [path]}" "${2:-}" "${3:-}" ;;
    diff)     cmd_diff "$@" ;;
    restore)  cmd_restore "${1:?usage: git mess restore <name>|--all [rev]}" "${2:-}" ;;
    move|mv)  cmd_move "${1:?usage: git mess move <old-name> <new-name>}" "${2:?usage: git mess move <old-name> <new-name>}" ;;
    delete)   cmd_delete "$@" ;;
    *)        usage ;;
esac
